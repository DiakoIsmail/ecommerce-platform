name: CI

on:
  push:
    branches: [main]
  pull_request:
    branches: [main]

jobs:
  product-service:
    runs-on: ubuntu-latest
    defaults:
      run:
        working-directory: product-service
    steps:
      - uses: actions/checkout@v4
      - uses: actions/setup-java@v4
        with:
          java-version: '21'
          distribution: 'temurin'
          cache: 'maven'
      - name: Build and test
        run: ./mvnw clean test
      - name: Build Docker image
        run: docker build -t product-service:${{ github.sha }} .

